{
  "dashboard": {
    "title": "WebSocket Chat Monitoring",
    "uid": "ws-chat",
    "panels": [
      {
        "title": "Active WebSocket Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "ws_connections_active",
            "legendFormat": "{{instance}}"
          }
        ]
      },
      {
        "title": "Messages/sec (Received)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(ws_messages_received_total[1m])",
            "legendFormat": "{{instance}}"
          }
        ]
      },
      {
        "title": "Messages/sec (Sent/Broadcast)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(ws_messages_sent_total[1m])",
            "legendFormat": "{{instance}}"
          }
        ]
      },
      {
        "title": "Rate Limit Rejections/sec",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rate(ws_ratelimit_hits_total[1m])",
            "legendFormat": "{{instance}}"
          }
        ]
      },
      {
        "title": "Message Processing Latency (p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(ws_message_processing_time_seconds_bucket[5m]))",
            "legendFormat": "p99 {{instance}}"
          },
          {
            "expr": "histogram_quantile(0.50, rate(ws_message_processing_time_seconds_bucket[5m]))",
            "legendFormat": "p50 {{instance}}"
          }
        ]
      },
      {
        "title": "JVM Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
            "legendFormat": "Heap MB {{instance}}"
          }
        ]
      }
    ],
    "time": { "from": "now-30m", "to": "now" },
    "refresh": "10s"
  }
}
